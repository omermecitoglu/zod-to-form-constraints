{
  "compilerOptions": {
    "ignoreDeprecations": "6.0", // https://github.com/egoist/tsup/issues/1388
    "types": ["node"],
    "lib": ["ESNext", "DOM"],
    "noImplicitReturns": true, // because this is a library
    "paths": {
      "~/*": ["./src/*"]
    },
  },
  "include": [
    "**/*.ts",
  ],
  "exclude": ["node_modules", "dist"]
}
