{
  "name": "@omer-x/zod-to-form-constraints",
  "version": "1.0.0",
  "description": "Generate React form element props from Zod schemas, mapping validation rules into native form constraints and attributes.",
  "keywords": [
    "typescript",
    "zod",
    "react",
    "form",
    "validation",
    "constraints",
    "attributes",
    "generator",
    "library",
    "open-source"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omermecitoglu/zod-to-form-constraints.git"
  },
  "bugs": {
    "url": "https://github.com/omermecitoglu/zod-to-form-constraints/issues"
  },
  "homepage": "https://github.com/omermecitoglu/zod-to-form-constraints#readme",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "Omer Mecitoglu",
    "email": "omer.mecitoglu@gmail.com",
    "url": "https://omermecitoglu.github.io"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "lint:fix": "eslint --fix --flag unstable_native_nodejs_ts_config",
    "test": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "peerDependencies": {
    "zod": "^4"
  },
  "devDependencies": {
    "@omer-x/eslint-config": "^2.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.2",
    "react": "^19.2.7",
    "semantic-release": "^25.0.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
